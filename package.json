{
  "name": "trendyol-price-optimizer",
  "version": "0.19.93",
  "description": "Magicland 3D Hub — Shopify + Trendyol price and net-profit tracker (desktop)",
  "author": "Magicland 3D",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Icepun/magicland3d-price-optimizer.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:publish": "npm run build && electron-builder --publish always && node scripts/upload-latest-yml.mjs",
    "seed:tex-cargo": "node scripts/seed-tex-cargo-rules.mjs",
    "icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^3.9.1",
    "@libsql/client": "^0.15.15",
    "@prisma/adapter-libsql": "^6.19.3",
    "@prisma/client": "^6.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.64.1",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.14.2",
    "basic-ftp": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.3",
    "lucide-react": "^0.469.0",
    "mqtt": "^5.15.1",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "papaparse": "^5.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "png-to-ico": "^3.0.1",
    "prisma": "^6.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "@libsql/client": "$@libsql/client",
    "@libsql/core": "0.15.15"
  },
  "build": {
    "appId": "com.magicland3d.trendyol-price-optimizer",
    "productName": "Magicland 3D Hub",
    "artifactName": "Magicland-3D-Hub-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "compression": "normal",
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "src/generated/prisma/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "icon": "build/icon.ico",
    "extraResources": [
      {
        "from": "prisma/dev.db",
        "to": "prisma/dev.db"
      }
    ],
    "asarUnpack": [
      "src/generated/prisma/**/*.node",
      "node_modules/@libsql/**",
      "node_modules/libsql/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business",
      "artifactName": "Magicland-3D-Hub-${version}-${arch}.${ext}",
      "identity": "Magicland 3D Hub",
      "notarize": false,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Magicland 3D Hub ${version}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Icepun",
        "repo": "magicland3d-price-optimizer",
        "releaseType": "draft"
      }
    ]
  }
}
