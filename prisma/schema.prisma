generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(cuid())
  barcode          String   @unique
  sku              String
  name             String
  /** Kullanıcının verdiği kısa takma ad — listede gösterilir ve aramada kullanılır. */
  alias            String?
  categoryName     String
  currentSalePrice Float
  listPrice        Float?
  stock            Int      @default(0)
  desi             Float?
  weight           Float?
  imageUrl         String?
  /** Görsel kullanıcı tarafından elle seçildi/yüklendi mi → sync (Yenile) onu EZMEZ. */
  imageManual      Boolean  @default(false)
  isActive         Boolean  @default(true)
  /** Kullanıcı tarafından listeden gizlendi mi (silmeden saklama). */
  hidden           Boolean  @default(false)
  /** Sipariş üzerine üretilir — stok tutulmaz, "stok 0" uyarısı verilmez. */
  madeToOrder      Boolean  @default(false)
  source           String   @default("manual")
  trendyolId       String?
  /** Trendyol productMainId — varyant grubu kimliği. Aynı productMainId'ye sahip ürünler birbirinin varyantıdır (renk, beden, boyut). */
  productMainId    String?
  /** Ait olduğu varyant grubu (genel başlık). Aynı gruptaki ürünler birbirinin eşit varyantıdır. */
  variantGroupId   String?
  /** Varyant için okunur etiket (örn. "Kırmızı"). Boşsa ürün adı kullanılır. */
  variantLabel     String?
  commissionRate   Float?
  commissionSource String?
  commissionUpdatedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cost            ProductCost?
  priceHistory    PriceHistory[]
  listings        Listing[]
  modelFiles      ProductModelFile[]
  /** Ait olduğu varyant grubu. */
  variantGroup    VariantGroup? @relation(fields: [variantGroupId], references: [id], onDelete: SetNull)

  @@index([variantGroupId])
}

/**
 * Varyant grubu = aynı ürünün farklı renk/boy seçeneklerini tek genel başlık altında
 * toplayan üst katman. Her seçenek ayrı bir Product'tır (Shopify'dan ayrı çekilmiş);
 * hepsi bu gruba bağlanır ve listede tek satırda toplanır. Hiçbir üye "ana ürün" değildir.
 */
model VariantGroup {
  id        String   @id @default(cuid())
  name      String
  /** Açıksa: gruba yüklenen baskı dosyaları tüm varyantlara fan-out edilir (aynı model, farklı renk). */
  shareModels Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

/**
 * Listing = bir ana ürünün belirli bir platformdaki kaydı.
 * Bir ana ürün (Product) 3 listing'e sahip olabilir: Shopify, Trendyol, Hepsiburada.
 * Her birinde farklı sale price, komisyon oranı override, kargo override.
 */
model Listing {
  id            String   @id @default(cuid())
  productId     String
  /** "shopify" | "trendyol" | "hepsiburada" */
  platform      String
  /** Platform tarafındaki kimlik (Shopify productId, Trendyol id, HB merchantSku) */
  externalId    String?
  /** Platform tarafındaki SKU/stockCode */
  externalSku   String?
  /** Bu platformdaki barkod (her platformda farklı olabilir). Siparişler bununla eşleşir. */
  barcode       String?
  /** Listelenen satış fiyatı (KDV dahil) */
  salePrice     Float
  listPrice     Float?
  stock         Int      @default(0)
  /** Bu platform için özel komisyon oranı override'ı (örn. HB %12). Null ise commissionRules kullanılır. */
  commissionRate    Float?
  /** Sabit komisyon override (TL) */
  commissionFixed   Float?
  /** Bu platform için özel kargo override (TL). Null ise cargoRules kullanılır. */
  cargoCost     Float?
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, platform])
  @@index([platform, isActive])
  @@index([externalId])
}

/**
 * Trendyol/Hepsiburada'dan çekilen ama Shopify ana ürününe barcode ile match olmayan listing'ler.
 * Kullanıcı bu listing'leri "Ürün Seç" modalı üzerinden manuel olarak bir Shopify ana ürününe
 * bağlayabilir. Match yapılınca buradan silinir ve Listing tablosuna eklenir.
 */
model UnmatchedListing {
  id          String   @id @default(cuid())
  platform    String   // "trendyol" | "hepsiburada"
  externalId  String?
  externalSku String?
  barcode     String
  name        String
  categoryName String?
  price       Float
  stock       Int      @default(0)
  imageUrl    String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([platform, externalId])
  @@index([platform, barcode])
}

model ProductCost {
  id             String  @id @default(cuid())
  productId      String  @unique
  costMode       String  @default("manual")
  templateId     String?

  // Per-product: filament
  filamentTypeId String?
  filamentWeight Float?
  printTimeHours Float?
  wasteRate      Float?

  // Per-product: packaging breakdown (legacy manual amounts — kept for backward compat)
  packagingPoset  Float?
  packagingNaylon Float?
  packagingBant   Float?
  packagingKart   Float?

  // Per-product: packaging SELECTIONS (fiyatlar Maliyet Ayarları'ndan çekilir,
  // zam yapılınca tüm ürünler otomatik güncellenir)
  /** Seçilen poşet/koli preset id (AppSetting.packagingOptions JSON'undaki id) */
  packagingOptionId String?
  /** Naylon seviyesi: "none" | "low" | "medium" | "high" */
  nylonLevel        String?
  /** Bant kullanılıyor mu */
  tapeUsed          Boolean?

  // Legacy / manual override
  manualCost      Float?
  materialWeight  Float?

  // Calculated breakdowns (cached)
  materialCost    Float?
  electricityCost Float?
  machineWearCost Float?
  laborCost       Float?
  packagingCost   Float?
  otherCost       Float?
  totalCost       Float?

  updatedAt DateTime @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  filamentType FilamentType? @relation(fields: [filamentTypeId], references: [id])
  template     CostTemplate? @relation(fields: [templateId], references: [id])
}

model FilamentType {
  id          String  @id @default(cuid())
  name        String
  costPerGram Float
  isActive    Boolean @default(true)

  productCosts ProductCost[]
}

/**
 * Filament makarası — fiziksel envanter. Her baskıda hangi makaranın kullanıldığı
 * seçilir, basılan modelin gramajı kadar remainingGrams düşülür. reorderGrams
 * eşiğinin altına inince "sipariş ver" uyarısı.
 */
model FilamentSpool {
  id             String   @id @default(cuid())
  name           String
  material       String   @default("PLA")
  colorName      String?
  colorHex       String   @default("#9ca3af")
  brand          String?
  totalGrams     Float    @default(1000)
  remainingGrams Float    @default(1000)
  spoolCost      Float?
  reorderGrams   Float    @default(200)
  vendorUrl      String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usages FilamentUsage[]
}

/** Bir makaradan filament düşüm kaydı (baskı / manuel). */
model FilamentUsage {
  id          String   @id @default(cuid())
  spoolId     String
  productId   String?
  productName String?
  grams       Float
  note        String?
  createdAt   DateTime @default(now())

  spool FilamentSpool @relation(fields: [spoolId], references: [id], onDelete: Cascade)

  @@index([spoolId])
}

model CostTemplate {
  id                     String  @id @default(cuid())
  name                   String
  materialCostPerGram    Float   @default(0)
  electricityCostPerHour Float   @default(0)
  machineWearCostPerHour Float   @default(0)
  defaultPackagingCost   Float   @default(0)
  defaultLaborCost       Float   @default(0)
  defaultOtherCost       Float   @default(0)
  defaultWasteRate       Float   @default(0)
  isActive               Boolean @default(true)

  productCosts ProductCost[]
}

model CommissionRule {
  id              String    @id @default(cuid())
  name            String
  categoryName    String?
  minPrice        Float     @default(0)
  maxPrice        Float     @default(999999)
  commissionRate  Float
  fixedCommission Float     @default(0)
  validFrom       DateTime?
  validTo         DateTime?
  priority        Int       @default(10)
  isActive        Boolean   @default(true)
}

model CargoRule {
  id            String    @id @default(cuid())
  name          String
  /** "trendyol" | "shopify" — hangi platformun kargo baremi. Null = tüm platformlar. */
  platform      String?
  cargoProvider String?
  categoryName  String?
  minPrice      Float     @default(0)
  maxPrice      Float     @default(999999)
  minDesi       Float     @default(0)
  maxDesi       Float     @default(999)
  cargoCost     Float
  validFrom     DateTime?
  validTo       DateTime?
  priority      Int       @default(10)
  isActive      Boolean   @default(true)
}

model ExpenseRule {
  id           String  @id @default(cuid())
  name         String
  /** "trendyol" | "shopify" — sadece o platforma uygulanır. Null = tüm platformlar (örn. KDV). */
  platform     String?
  type         String
  value        Float
  categoryName String?
  minPrice     Float   @default(0)
  maxPrice     Float   @default(999999)
  priority     Int     @default(10)
  isActive     Boolean @default(true)
}

model PriceHistory {
  id           String   @id @default(cuid())
  productId    String
  oldPrice     Float
  newPrice     Float
  changeSource String
  changedAt    DateTime @default(now())
  note         String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key   String @id
  value String
}

/**
 * Fiziksel 3D yazıcı bağlantısı. Moonraker (Elegoo Neptune 4 Pro/Plus, Snapmaker U1)
 * veya Bambu (A1) — host/IP üzerinden LAN'da canlı durum + kontrol.
 */
model PrinterConfig {
  id         String   @id @default(cuid())
  name       String
  /** "elegoo" | "snapmaker" | "bambu" */
  brand      String
  model      String?
  /** "moonraker" | "bambu" */
  type       String   @default("moonraker")
  /** IP veya hostname, örn. "192.168.1.18" */
  host       String
  /** Moonraker varsayılan 7125; Bambu MQTT 8883 */
  port       Int      @default(7125)
  /** Kart vurgu rengi (oklch). Boşsa palette'ten atanır. */
  accent     String?
  /** Bambu LAN access code (yazıcı ekranından). */
  accessCode String?
  /** Bambu cihaz seri no. */
  serial     String?
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/**
 * Bir yazıcıdaki belirli bir gcode dosyasının hangi katalog ürününe karşılık geldiği
 * (manuel eşleştirme). Aynı dosya tekrar basılınca ürün otomatik hatırlanır.
 */
model PrintFileProduct {
  id              String   @id @default(cuid())
  printerConfigId String
  filename        String
  productId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([printerConfigId, filename])
  @@index([productId])
}

/**
 * Bir ürünün belirli bir yazıcı için dilimlenmiş baskı dosyası (gcode/3mf).
 * Dosya byte'ları uygulama tarafında diskte (userData/models) saklanır; burada
 * sadece metadata + disk yolu tutulur. "Bas" → dosya yazıcıya yüklenip başlatılır.
 */
model ProductModelFile {
  id              String   @id @default(cuid())
  productId       String
  printerConfigId String
  /** Parça adı (örn. "Gövde", "Kapak"). Bir ürün+yazıcı için birden çok parça olabilir. */
  label           String?
  /** Kullanıcının orijinal dosya adı (yazıcıya bu adla yüklenir). */
  originalName    String
  /** Diskteki tam yol (userData/models/...). R2'ye yüklenen dosyalarda boş ("") — r2Key kullanılır. */
  storedPath      String
  /** Cloudflare R2 nesne anahtarı (örn. "models/uuid.gcode"). Doluysa dosya BULUTTA → tüm cihazlardan erişilir. Null = eski yerel dosya. */
  r2Key           String?
  /** "gcode" | "gco" | "3mf" */
  fileType        String
  sizeBytes       Int      @default(0)
  /** Filament gramajı (maliyet + makara düşümü entegrasyonu için, opsiyonel). */
  gramaj          Float?
  /** Tahmini baskı süresi (dakika, opsiyonel). */
  estPrintMin     Int?
  /** Dosyadan okunan filament renkleri (JSON: {colors,source,fileKind}) — yüklemede/ilk açılışta
      BİR KEZ parse edilip saklanır; SlotStep her açılışta dosyayı (R2'den indirip) yeniden
      açmasın, baskı başlatma senkron unzip ile ana süreci dondurmasın. */
  colorsJson      String?
  /** Dosya dilimlenmiş mi (3mf için) — baskı öncesi kontrolün kalıcı sonucu. */
  sliced          Boolean?
  /** Bambu plaka meta (JSON: {plateParam,filamentCount}) — ilk baskıda parse edilip saklanır. */
  plateJson       String?
  /** Dilimleyicinin gcode/3mf'e gömdüğü önizleme görseli (data URL) — arşiv/listelerde küçük
      görsel için. Yüklemede çıkarılır; eski dosyalar ilk baskıda dolar (backfill). */
  thumbnail       String?
  /** Dosya içeriğinin MD5'i (hex) — yazıcıda "zaten var" tespiti için kimlik. Yükleme adına
      gömülür (stem-md5ilk10.ext); ad+boyut eşleşmesi = kesin aynı içerik (isim tahmini değil). */
  contentMd5      String?
  /** Parça sıralaması (aynı ürün+yazıcı içinde). */
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([printerConfigId])
  @@index([productId, printerConfigId])
}

/**
 * Yazıcının son canlı durumu — masaüstü (LAN'da) periyodik yazar, telefon okur.
 * Telefon LAN'a erişemediği için uzaktan izlemeyi bu snapshot sağlar.
 */
model PrinterSnapshot {
  printerConfigId String   @id
  name            String
  brand           String
  /** printing | paused | finished | idle | error | offline */
  status          String
  /** Hata/duraklatma nedeni (Moonraker print_stats.message / Bambu hata kodu). Bildirimde gösterilir. */
  statusMessage   String?
  online          Boolean  @default(false)
  productName     String?
  productImage    String?
  /** 0..1 */
  progress        Float    @default(0)
  nozzle          Int      @default(0)
  bed             Int      @default(0)
  currentFilename String?
  /** Kalan saniye (varsa). */
  etaSec          Int?
  updatedAt       DateTime @updatedAt
}

/**
 * Telefondan (ya da başka cihazdan) gönderilen baskı komutu. Masaüstü relay'i
 * bekleyen komutları işler (LAN'da yazıcıya uygular) ve sonucu yazar.
 */
model PrintCommand {
  id              String    @id @default(cuid())
  printerConfigId String
  /** start | pause | resume | cancel */
  action          String
  /** start için: basılacak model dosyası (ProductModelFile.id). */
  modelFileId     String?
  /** pending | done | error */
  status          String    @default("pending")
  error           String?
  /** Komutu gönderen ("mobile" vb.). */
  source          String?
  createdAt       DateTime  @default(now())
  processedAt     DateTime?

  @@index([status])
}

/**
 * Kalıcı bildirim — olay-anında üretilir (ör. stoğu biten/sipariş-üzerine ürüne
 * sipariş gelmesi). `id` aynı zamanda tekilleştirme anahtarıdır (örn.
 * "order-stock:ty-123:prod_abc") → createMany(skipDuplicates) ile tekrar yazılmaz.
 * Düşük stok / filament / yazıcı uyarıları ANLIK hesaplanır (bu tabloda DEĞİL).
 */
model Notification {
  id             String    @id
  /** order-stock | order-made | printer-done | printer-error */
  type           String
  /** critical | warning | success */
  severity       String
  title          String
  body           String
  href           String
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?

  @@index([acknowledgedAt])
}

/**
 * Expo push token'ları — mobil uygulama açılışta kendi token'ını yazar; masaüstü relay'i baskı
 * bitince bu token'lara push gönderir (telefon kapalıyken de bildirim düşer). Turso senkronlar.
 */
model PushToken {
  token     String   @id
  /** ios | android */
  platform  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
