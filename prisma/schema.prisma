generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(cuid())
  barcode          String   @unique
  sku              String
  name             String
  categoryName     String
  currentSalePrice Float
  listPrice        Float?
  stock            Int      @default(0)
  desi             Float?
  weight           Float?
  imageUrl         String?
  isActive         Boolean  @default(true)
  /** Kullanıcı tarafından listeden gizlendi mi (silmeden saklama). */
  hidden           Boolean  @default(false)
  source           String   @default("manual")
  trendyolId       String?
  /** Trendyol productMainId — varyant grubu kimliği. Aynı productMainId'ye sahip ürünler birbirinin varyantıdır (renk, beden, boyut). */
  productMainId    String?
  /** Bu ürün başka bir ürünün varyantıysa, ana ürünün id'si. Varyantlar ana listede gizlenir, ana ürünün altında görünür. */
  parentProductId  String?
  /** Varyant için okunur etiket (örn. "Kırmızı"). Boşsa ürün adı kullanılır. */
  variantLabel     String?
  commissionRate   Float?
  commissionSource String?
  commissionUpdatedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cost            ProductCost?
  priceHistory    PriceHistory[]
  listings        Listing[]
  /** Bu ürün bir varyantsa bağlı olduğu ana ürün. */
  parent          Product?  @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: SetNull)
  /** Bu ürünün varyantları (alt ürünler). */
  variantChildren Product[] @relation("ProductVariants")
}

/**
 * Listing = bir ana ürünün belirli bir platformdaki kaydı.
 * Bir ana ürün (Product) 3 listing'e sahip olabilir: Shopify, Trendyol, Hepsiburada.
 * Her birinde farklı sale price, komisyon oranı override, kargo override.
 */
model Listing {
  id            String   @id @default(cuid())
  productId     String
  /** "shopify" | "trendyol" | "hepsiburada" */
  platform      String
  /** Platform tarafındaki kimlik (Shopify productId, Trendyol id, HB merchantSku) */
  externalId    String?
  /** Platform tarafındaki SKU/stockCode */
  externalSku   String?
  /** Listelenen satış fiyatı (KDV dahil) */
  salePrice     Float
  listPrice     Float?
  stock         Int      @default(0)
  /** Bu platform için özel komisyon oranı override'ı (örn. HB %12). Null ise commissionRules kullanılır. */
  commissionRate    Float?
  /** Sabit komisyon override (TL) */
  commissionFixed   Float?
  /** Bu platform için özel kargo override (TL). Null ise cargoRules kullanılır. */
  cargoCost     Float?
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, platform])
  @@index([platform, isActive])
  @@index([externalId])
}

/**
 * Trendyol/Hepsiburada'dan çekilen ama Shopify ana ürününe barcode ile match olmayan listing'ler.
 * Kullanıcı bu listing'leri "Ürün Seç" modalı üzerinden manuel olarak bir Shopify ana ürününe
 * bağlayabilir. Match yapılınca buradan silinir ve Listing tablosuna eklenir.
 */
model UnmatchedListing {
  id          String   @id @default(cuid())
  platform    String   // "trendyol" | "hepsiburada"
  externalId  String?
  externalSku String?
  barcode     String
  name        String
  categoryName String?
  price       Float
  stock       Int      @default(0)
  imageUrl    String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([platform, externalId])
  @@index([platform, barcode])
}

model ProductCost {
  id             String  @id @default(cuid())
  productId      String  @unique
  costMode       String  @default("manual")
  templateId     String?

  // Per-product: filament
  filamentTypeId String?
  filamentWeight Float?
  printTimeHours Float?
  wasteRate      Float?

  // Per-product: packaging breakdown (legacy manual amounts — kept for backward compat)
  packagingPoset  Float?
  packagingNaylon Float?
  packagingBant   Float?
  packagingKart   Float?

  // Per-product: packaging SELECTIONS (fiyatlar Maliyet Ayarları'ndan çekilir,
  // zam yapılınca tüm ürünler otomatik güncellenir)
  /** Seçilen poşet/koli preset id (AppSetting.packagingOptions JSON'undaki id) */
  packagingOptionId String?
  /** Naylon seviyesi: "none" | "low" | "medium" | "high" */
  nylonLevel        String?
  /** Bant kullanılıyor mu */
  tapeUsed          Boolean?

  // Legacy / manual override
  manualCost      Float?
  materialWeight  Float?

  // Calculated breakdowns (cached)
  materialCost    Float?
  electricityCost Float?
  machineWearCost Float?
  laborCost       Float?
  packagingCost   Float?
  otherCost       Float?
  totalCost       Float?

  updatedAt DateTime @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  filamentType FilamentType? @relation(fields: [filamentTypeId], references: [id])
  template     CostTemplate? @relation(fields: [templateId], references: [id])
}

model FilamentType {
  id          String  @id @default(cuid())
  name        String
  costPerGram Float
  isActive    Boolean @default(true)

  productCosts ProductCost[]
}

/**
 * Filament makarası — fiziksel envanter. Her baskıda hangi makaranın kullanıldığı
 * seçilir, basılan modelin gramajı kadar remainingGrams düşülür. reorderGrams
 * eşiğinin altına inince "sipariş ver" uyarısı.
 */
model FilamentSpool {
  id             String   @id @default(cuid())
  name           String
  material       String   @default("PLA")
  colorName      String?
  colorHex       String   @default("#9ca3af")
  brand          String?
  totalGrams     Float    @default(1000)
  remainingGrams Float    @default(1000)
  spoolCost      Float?
  reorderGrams   Float    @default(200)
  vendorUrl      String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usages FilamentUsage[]
}

/** Bir makaradan filament düşüm kaydı (baskı / manuel). */
model FilamentUsage {
  id          String   @id @default(cuid())
  spoolId     String
  productId   String?
  productName String?
  grams       Float
  note        String?
  createdAt   DateTime @default(now())

  spool FilamentSpool @relation(fields: [spoolId], references: [id], onDelete: Cascade)

  @@index([spoolId])
}

model CostTemplate {
  id                     String  @id @default(cuid())
  name                   String
  materialCostPerGram    Float   @default(0)
  electricityCostPerHour Float   @default(0)
  machineWearCostPerHour Float   @default(0)
  defaultPackagingCost   Float   @default(0)
  defaultLaborCost       Float   @default(0)
  defaultOtherCost       Float   @default(0)
  defaultWasteRate       Float   @default(0)
  isActive               Boolean @default(true)

  productCosts ProductCost[]
}

model CommissionRule {
  id              String    @id @default(cuid())
  name            String
  categoryName    String?
  minPrice        Float     @default(0)
  maxPrice        Float     @default(999999)
  commissionRate  Float
  fixedCommission Float     @default(0)
  validFrom       DateTime?
  validTo         DateTime?
  priority        Int       @default(10)
  isActive        Boolean   @default(true)
}

model CargoRule {
  id            String    @id @default(cuid())
  name          String
  /** "trendyol" | "shopify" — hangi platformun kargo baremi. Null = tüm platformlar. */
  platform      String?
  cargoProvider String?
  categoryName  String?
  minPrice      Float     @default(0)
  maxPrice      Float     @default(999999)
  minDesi       Float     @default(0)
  maxDesi       Float     @default(999)
  cargoCost     Float
  validFrom     DateTime?
  validTo       DateTime?
  priority      Int       @default(10)
  isActive      Boolean   @default(true)
}

model ExpenseRule {
  id           String  @id @default(cuid())
  name         String
  /** "trendyol" | "shopify" — sadece o platforma uygulanır. Null = tüm platformlar (örn. KDV). */
  platform     String?
  type         String
  value        Float
  categoryName String?
  minPrice     Float   @default(0)
  maxPrice     Float   @default(999999)
  priority     Int     @default(10)
  isActive     Boolean @default(true)
}

model PriceHistory {
  id           String   @id @default(cuid())
  productId    String
  oldPrice     Float
  newPrice     Float
  changeSource String
  changedAt    DateTime @default(now())
  note         String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key   String @id
  value String
}
